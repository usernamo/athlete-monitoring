{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "framework": null,
  "installCommand": "npm install && npm install --prefix backend",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api"
    }
  ],
  "functions": {
    "api/index.js": {
      "memory": 1024,
      "maxDuration": 60,
      "includeFiles": "database/**"
    }
  },
  "crons": [
    {
      "path": "/health",
      "schedule": "*/10 * * * *"
    }
  ]
}
